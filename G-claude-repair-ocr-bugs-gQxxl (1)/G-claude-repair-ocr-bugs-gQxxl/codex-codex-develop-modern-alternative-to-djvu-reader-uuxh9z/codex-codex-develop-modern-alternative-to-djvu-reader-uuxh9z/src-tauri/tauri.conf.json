{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NovaReader",
  "version": "4.0.0",
  "identifier": "com.novareader.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "NovaReader",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' https://cdn.jsdelivr.net https://unpkg.com https://tessdata.projectnaptha.com; worker-src 'self' blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "fileAssociations": [
      {
        "ext": ["pdf"],
        "mimeType": "application/pdf",
        "description": "PDF Document",
        "role": "Editor"
      },
      {
        "ext": ["djvu", "djv"],
        "mimeType": "image/vnd.djvu",
        "description": "DjVu Document",
        "role": "Viewer"
      },
      {
        "ext": ["epub"],
        "mimeType": "application/epub+zip",
        "description": "ePub Book",
        "role": "Viewer"
      },
      {
        "ext": ["cbz"],
        "mimeType": "application/vnd.comicbook+zip",
        "description": "Comic Book Archive",
        "role": "Viewer"
      }
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "nsis": {
        "displayLanguageSelector": true,
        "languages": ["English", "Russian"],
        "installerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "fs": {
      "scope": {
        "allow": ["$APPDATA/**", "$DOCUMENT/**", "$DOWNLOAD/**", "$HOME/**", "$DESKTOP/**"],
        "deny": ["$APPDATA/novareader/secrets/**"]
      }
    },
    "dialog": {
      "open": true,
      "save": true
    },
    "shell": {
      "open": true
    }
  }
}
