{
  "identifier": "default",
  "description": "Default capabilities for NovaReader",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "dialog:allow-confirm",
    "fs:default",
    "fs:allow-read",
    "fs:allow-write",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-stat",
    "fs:scope-appdata-recursive",
    "fs:scope-document-recursive",
    "fs:scope-download-recursive",
    "fs:scope-home-recursive",
    "fs:scope-desktop-recursive",
    "shell:allow-open",
    "process:default",
    "os:default"
  ]
}
