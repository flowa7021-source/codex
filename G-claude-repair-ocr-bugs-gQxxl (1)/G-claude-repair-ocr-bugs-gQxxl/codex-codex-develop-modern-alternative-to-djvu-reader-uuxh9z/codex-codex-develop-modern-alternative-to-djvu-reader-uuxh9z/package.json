{
  "name": "novareader-desktop",
  "version": "2.0.0-alpha",
  "description": "NovaReader desktop build (no Python/server runtime)",
  "main": "electron/main.js",
  "author": "NovaReader",
  "license": "MIT",
  "scripts": {
    "start:desktop": "electron .",
    "dev": "vite --config vite.config.js",
    "build:web": "vite build --config vite.config.js",
    "preview": "vite preview --config vite.config.js",
    "build:win": "electron-builder --win portable",
    "build:win:nosign": "electron-builder --win portable --config.win.signAndEditExecutable=false",
    "test:e2e": "npx playwright test --config tests/e2e/playwright.config.js",
    "test:e2e:desktop": "npx playwright test --config tests/e2e/playwright.config.js --project=desktop-hd",
    "test:e2e:mobile": "npx playwright test --config tests/e2e/playwright.config.js --project=mobile",
    "test:unit": "node --test tests/unit/*.test.js",
    "test:benchmark": "node tests/benchmarks/ocr-quality-baseline.js",
    "test:soak": "node tests/nightly-soak.js",
    "test:soak:long": "SOAK_DURATION_MIN=60 node tests/nightly-soak.js",
    "test": "npm run test:benchmark"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "djvujs-dist": "^0.5.4",
    "electron": "30.5.1",
    "electron-builder": "24.13.3",
    "pdfjs-dist": "^4.4.168",
    "tesseract.js": "^5.1.1",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.novareader.desktop",
    "productName": "NovaReader",
    "directories": {
      "output": "dist"
    },
    "files": [
      "app/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "artifactName": "NovaReader-${version}.${ext}"
    }
  },
  "engines": {
    "node": ">=22 <23"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "docx": "^9.6.1",
    "pdf-lib": "^1.17.1"
  }
}
