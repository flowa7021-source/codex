{
  "name": "novareader",
  "version": "1.0.0",
  "description": "Professional PDF viewer and creator with Adobe Acrobat-level quality",
  "main": "electron/main.js",
  "scripts": {
    "dev": "webpack serve --mode development",
    "build": "webpack --mode production",
    "build:electron": "npm run build && tsc -p electron/tsconfig.json",
    "build:win:nosign": "npm run build:electron && electron-builder --win portable --config electron-builder.yml",
    "start": "electron .",
    "lint": "eslint app/"
  },
  "dependencies": {
    "pdfjs-dist": "^4.9.155",
    "jspdf": "^2.5.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "css-loader": "^7.1.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "html-webpack-plugin": "^5.6.3",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.7.2",
    "webpack": "^5.97.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.0",
    "copy-webpack-plugin": "^12.0.2"
  }
}
