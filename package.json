{
  "name": "novareader",
  "version": "4.0.0",
  "description": "NovaReader — modern document viewer for PDF, DJVU, ePub with OCR",
  "type": "module",
  "author": "NovaReader",
  "license": "MIT",
  "scripts": {
    "dev": "vite --config vite.config.js",
    "build": "vite build --config vite.config.js && node scripts/obfuscate-dist.js",
    "build:dev": "NOVA_SKIP_OBFUSCATION=1 vite build --config vite.config.js",
    "build:clean": "vite build --config vite.config.js",
    "preview": "vite preview --config vite.config.js",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "test:e2e": "npx playwright test --config tests/e2e/playwright.config.js",
    "test:e2e:desktop": "npx playwright test --config tests/e2e/playwright.config.js --project=desktop-hd",
    "test:e2e:mobile": "npx playwright test --config tests/e2e/playwright.config.js --project=mobile",
    "test:unit": "node --import ./tests/unit/setup-dom.js --test tests/unit/*.test.js",
    "test:benchmark": "node tests/benchmarks/ocr-quality-baseline.js",
    "test:benchmark:ocr": "node tests/benchmarks/ocr-corpus-benchmark.js",
    "test:benchmark:pdf": "node tests/benchmarks/pdf-conversion-benchmark.js",
    "test:soak": "node tests/nightly-soak.js",
    "test:soak:long": "SOAK_DURATION_MIN=60 node tests/nightly-soak.js",
    "check:bundle": "node scripts/check-bundle-size.js",
    "lint": "eslint app/ --max-warnings 0",
    "lint:fix": "eslint app/ --fix",
    "test": "npm run test:benchmark",
    "test:coverage": "c8 --reporter=text --reporter=lcov node --import ./tests/unit/setup-dom.js --test tests/unit/*.test.js",
    "test:coverage:check": "c8 check-coverage --lines 40 --functions 30 --branches 30",
    "test:visual": "npx playwright test tests/e2e/visual-regression.spec.js",
    "typecheck": "tsc --noEmit",
    "release": "standard-version",
    "lighthouse": "lhci autorun",
    "analyze": "npm run build && node scripts/analyze-bundle.js"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-fs": "^2",
    "@tauri-apps/plugin-os": "^2",
    "@tauri-apps/plugin-process": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "docx": "^9.6.1",
    "fflate": "^0.8.2",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.45.0",
    "@tauri-apps/cli": "^2",
    "@types/node": "^22.0.0",
    "c8": "^10.0.0",
    "djvujs-dist": "^0.5.4",
    "eslint": "^9.39.4",
    "javascript-obfuscator": "^5.3.1",
    "pdfjs-dist": "^4.4.168",
    "rollup-plugin-obfuscator": "^1.1.0",
    "standard-version": "^9.5.0",
    "tesseract.js": "^5.1.1",
    "typescript": "^5.7.0",
    "vite": "^6.4.1"
  },
  "engines": {
    "node": ">=18"
  }
}
